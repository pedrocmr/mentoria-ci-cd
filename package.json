{
  "name": "mentoria-ci-cd",
  "version": "1.0.0",
  "description": "Mentoria CI/CD project with trunk-based development and fake environment deployments",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
